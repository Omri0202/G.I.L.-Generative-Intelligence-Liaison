# Secrets — never commit these
.env
credentials.py

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/
*.egg

# Virtual environments
venv/
.venv/
env/

# MediaPipe model (large binary, re-downloadable)
data/hand_landmarker.task

# Face recognition data (personal biometric data -- never commit)
data/face_db/
data/face_embeddings.json

# Auth tokens / browser session data -- never commit
data/.spotify_cache
data/whatsapp_profile/
data/*.token
data/*.session
data/gmail_token.json
data/gmail_credentials.json
data/calendar_token.json
data/lg_tv_key.json

# Databases (contain personal conversation history)
data/gil_brain.db
data/gil_memory.json
data/chat_history.db
database/

# Personal user data — each install creates its own profile
data/user_profile.json
data/learning_projects/
data/dev_config.json
data/session_memory.json
data/missions.json
data/generated_images/
data/3d_projects/

# Build artefacts — generated by build.py
gil.spec
gil_installer.iss

# Temp / runtime files
*.log
*.tmp
*.bak

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.suo
*.user
